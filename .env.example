OPENAI_API_KEY=your_openai_api_key_here

# Stripe (server-side). Required for checkout.
STRIPE_SECRET_KEY=

# Backend (Railway): mount a persistent volume at /data and set DATABASE_PATH
DATABASE_PATH=/data/app.sqlite

# --- Auth (Google OAuth) ---
# Required to enable Google login endpoints in the Node server.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:3000/api/auth/google/callback

# Used to sign cookies (required for tamper-resistant sessions in production)
SESSION_SECRET=

# Where to redirect the user after Google login completes.
# In production set this to your public origin, e.g. https://yourdomain.com
APP_ORIGIN=http://localhost:3000
